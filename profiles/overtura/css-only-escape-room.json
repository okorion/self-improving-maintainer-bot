{
  "repository": "overtura/css-only-escape-room",
  "defaultBranch": "main",
  "worktree": "targets/overtura/css-only-escape-room",
  "scope": "docs",
  "docPaths": ["README.md", "DESIGN.md", "docs", "maintainer-bot"],
  "evalsPath": "maintainer-bot/evals/docs_qa.jsonl",
  "verifyCommands": [
    "pnpm install --frozen-lockfile || pnpm install",
    "pnpm check"
  ],
  "allowPaths": [
    "README.md",
    "DESIGN.md",
    "docs/**",
    "maintainer-bot/**",
    "index.html",
    "styles.css",
    "design-system/**"
  ],
  "denyPaths": [
    ".github/workflows/**",
    "CODEOWNERS",
    ".env*",
    ".npmrc",
    "src/**",
    "scripts/**",
    "infra/**",
    "terraform/**",
    "k8s/**",
    "migrations/**",
    "**/*.js",
    "**/*.ts",
    "*.pem",
    "*.key"
  ],
  "maxFiles": 10,
  "maxLines": 250,
  "autoMerge": false
}
