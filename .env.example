GITHUB_TOKEN=
GITHUB_REPOSITORY=OWNER/REPO
BOT_GITHUB_TOKEN=

# Target repository managed by this bot. Leave blank to manage this repository itself.
# Example: TARGET_REPOSITORY=OWNER/TARGET_REPO
TARGET_REPOSITORY=
TARGET_DEFAULT_BRANCH=main
TARGET_WORKTREE=targets/active
TARGET_DOC_PATHS=README.md,docs
# Optional target-specific eval cases. Leave blank to use this bot's evals.
TARGET_EVALS_PATH=

# Optional. Set only when the Codex CLI is not on PATH.
CODEX_CLI=
CODEX_TIMEOUT_SECONDS=3600
